  m_Script: {fileID: 11500000, guid: a391a8e9c877e3f4080e6c52971b67dc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuestZoneTrigger
  questManager: {fileID: 1726363788}
  halamanQuest:
  - 'SELAMAT! Anda berhasil mendapatkan item headphone.

    Headphone ini dapat
    membantu membuat suasana pendakian menjadi lebih tenang. Simak tutorial berikut
    untuk penggunaan headphone.'
  - '1. Ambil headphone menggunakan grip.

    2. Arahkan headphone ke area kepala.'
  - '1. Lepaskan grip saat headphone sudah berada di dekat area kepala.

    2. Headphone
    akan terpasang, lalu musik akan menyala secara otomatis.'
  - 'Untuk menjeda atau melanjutkan musik, arahkan tangan ke area kepala, lalu tekan
    tombol trigger.

    Tekan trigger lagi jika ingin memutar musik kembali.'
  - 'Untuk melepas headphone, arahkan tangan ke area kepala, lalu gunakan grip untuk
    mengambil headphone.

    Setelah itu, arahkan headphone menjauh dari kepala
    atau ke luar area kepala.'
  - 'Gunakan headphone ini untuk membuat perjalananmu lebih santai.

    Jika sudah
    siap, lanjutkan perjalanan menuju pos berikutnya.'
  gambarQuest: []
  cubeVisualBarrier: {fileID: 0}
  matikanCubeVisualDiAwal: 1
  aktifkanCubeVisualSaatTrigger: 1
  barrierParentUntukDihilangkan: {fileID: 1655249728}
  hilangkanBarrierSaatTrigger: 0
  hancurkanSetelahTrigger: 1

  m_Script: {fileID: 11500000, guid: a391a8e9c877e3f4080e6c52971b67dc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuestZoneTrigger
  questManager: {fileID: 1726363788}
  halamanQuest:
  - Halo, selamat datang di pendakian virtualmu! Ini adalah Quest Window yang akan
    memandu perjalananmu. Anggap saja ini waktu santaimu untuk melepas penat dan
    menikmati alam. Tujuan akhir perjalanan kita adalah mencapai puncak gunung. Yuk
    simak tutorial penggunaan Controller berikut ini!
  - 'Joystick Kiri - Berjalan

    Joystick Kanan - Putar Kanan / Kiri

    Tombol
    A - Melompat'
  - 'Trigger - Mengkonfirmasi pilihan (klik)

    Grip - Mengambil objek'
  - 'Tombol B - Membuka Radial Menu

    Tab Volume - Mute / Unmute Suara

    Tab
    Panel  - Untuk Mengaktifkan Quest Wiindow

    Tab Exit - Kembali ke Main Menu'
  gambarQuest:
  - {fileID: 21300000, guid: e883441ca7da7354fac787a4a20cc8a3, type: 3}
  - {fileID: 21300000, guid: f711dc313b41ce544ae4c920365ab184, type: 3}
